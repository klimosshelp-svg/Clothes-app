# ─────────────────────────────────────────────────────────────
# Arwin — environment configuration
# Copy this file to `.env.local` and fill in what you need.
# The app runs fully WITHOUT any of these set (mock mode).
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI provider ──────────────────────────────────────────────
# Which try-on engine to use: "mock" | "replicate" | "openai" | "runware"
# Defaults to "mock" if unset — the app works out of the box.
AI_PROVIDER=mock

# Replicate (https://replicate.com) — used when AI_PROVIDER=replicate
REPLICATE_API_TOKEN=
# Model slug for a virtual try-on model, e.g. an IDM-VTON deployment.
REPLICATE_TRYON_MODEL=

# OpenAI (image edit/gen) — used when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# Runware (https://runware.ai) — used when AI_PROVIDER=runware
RUNWARE_API_KEY=

# ── Supabase (optional) ──────────────────────────────────────
# If unset, Arwin falls back to LOCAL storage (public/uploads) and a
# LOCAL JSON gallery (.data/gallery.json) so you can run with no backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used for uploads + inserts.
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name (create it in the Supabase dashboard).
SUPABASE_STORAGE_BUCKET=arwin

# ── Cloudinary (optional alternative to Supabase Storage) ────
# CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud_name>
